<?xml version='1.0' encoding='UTF-8'?>
<system-manifest xmlns="urn:xmpp:xtrpg:system:0"
                 urn="urn:xmpp:xtrpg:system:vendor:com.wizards:dnd:5.5">

	<attributes>

		<!-- D&D Strength Attribute -->
		<integer id="strength">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>

		<!-- D&D Strength Modifier -->
		<integer id='strength_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="strength" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<integer id="dexterity" />
		<integer id='dexterity_modifier'>
			<calculation>
