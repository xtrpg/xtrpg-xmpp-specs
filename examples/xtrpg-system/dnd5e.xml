			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="wisdom" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<integer id="intelligence" />
