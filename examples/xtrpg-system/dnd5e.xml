<?xml version='1.0' encoding='UTF-8'?>
<system-manifest xmlns="urn:xmpp:xtrpg:system:0"
                 urn="urn:xmpp:xtrpg:system:vendor:com.wizards:dnd:5.5">

	<dice-definitions>
		<die id='coin'>
			<face>
				<symbol value='head' />
				<symbol value='heads' />
				<symbol value='yes' />
				<symbol value='even' />
				<symbol value='evens' />
			</face>
			<face>
				<symbol value='tail' />
				<symbol value='tails' />
				<symbol value='no' />
				<symbol value='odd' />
				<symbol value='odds' />
			</face>
		</die>
		<die id='d4' faces='4' />
		<die id='d6' faces='6' />
		<die id='d8' faces='8' />
		<die id='d10' faces='10' />
		<die id='d12' faces='12' />
		<die id='d20' faces='20' />
		<die id='d100' faces='100' />
	</dice-definitions>

	<attributes>

		<!-- D&D Initiative Modifier Attribute -->
		<integer id="initiative_modifier">
			<calculation>
				<attribute ref='dexterity_modifier' />
			</calculation>
		</integer>

		<!-- D&D Strength Attribute -->
		<integer id="strength">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>
		<integer id='strength_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="strength" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<!-- D&D Dexterity Attribute -->
		<integer id="dexterity">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>
		<integer id='dexterity_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="dexterity" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<!-- D&D Constitution Attribute -->
		<integer id="constitution">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>
		<integer id='constitution_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="constitution" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<!-- D&D Wisdom Attribute -->
		<integer id="wisdom">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>
		<integer id='wisdom_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="wisdom" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<!-- D&D Intelligence Attribute -->
		<integer id="intelligence">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>
		<integer id='intelligence_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="intelligence" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>

		<!-- D&D Charisma Attribute -->
		<integer id="charisma">
			<constraints>
				<min>
					<integer value='0' />
				</min>
				<max>
					<integer value='30' />
				</max>
				<default>
					<integer value='10' />
				</default>
			</constraints>
		</integer>
		<integer id='charisma_modifier'>
			<calculation>
				<round method="down" decimalPlaces="0">
					<divide>
						<subtract>
							<attribute ref="charisma" />
							<integer value="10" />
						</subtract>
						<integer value="2" />
					</divide>
				</round>
			</calculation>
		</integer>



	</attributes>



</system-manifest>